datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("USER")  // Changed from UserRole to String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  predictions Prediction[]
}

model Prediction {
  id                String   @id @default(cuid())
  userId            String
  city              String
  predictionDate    DateTime
  baselineTemp      Float
  rlCorrectedTemp   Float
  confidenceScore   Float
  actualTemp        Float?
  accuracy          Float?
  createdAt         DateTime @default(now())
  modelVersion      String
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([city])
}